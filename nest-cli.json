{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "modules/image/prompts/**/*.md", "outDir": "dist" },
      { "include": "modules/influencer/prompts/**/*.md", "outDir": "dist" },
      { "include": "modules/text/prompts/**/*.md", "outDir": "dist" }
    ]
  }
}
